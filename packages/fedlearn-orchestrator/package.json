{
  "name": "@viyrockan/fedlearn-orchestrator",
  "version": "0.1.1",
  "description": "Guaranteed per-turn orchestration wrapper for FedLearn MCP tool flow",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "fedlearn-guaranteed-chat": "bin/fedlearn-guaranteed-chat.mjs"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "dependencies": {
    "fedlearn-core": "^0.2.4"
  },
  "devDependencies": {
    "typescript": "5.4.5"
  }
}

