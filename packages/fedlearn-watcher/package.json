{
  "name": "@viyrockan/fedlearn-watcher",
  "version": "0.1.2",
  "description": "FedLearn Cursor disk watcher: learn from state.vscdb read-only, write .cursor/rules/fedlearn.generated.mdc",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "fedlearn-watcher": "bin/fedlearn-watcher.mjs"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "fedlearn-core": "^0.2.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "typescript": "5.4.5"
  }
}
